# ============================================================
# The Verdict: 환경 변수 설정 가이드
# ============================================================
# 이 파일을 .env.local로 복사하고 실제 값을 입력하세요:
#   cp .env.example .env.local

# ── Gemini AI ────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── AWS 기본 설정 ────────────────────────────────────────────
AWS_REGION=us-east-1

# ── API Gateway (Lambda 배포 후 생성됨) ──────────────────────
NEXT_PUBLIC_API_URL=https://your-api-gateway-url.execute-api.us-east-1.amazonaws.com/prod

# ── RDS (기존 데이터베이스) ──────────────────────────────────
DB_HOST=your-rds-endpoint.us-east-1.rds.amazonaws.com
DB_PORT=3306
DB_NAME=the_verdict
DB_USER=admin
DB_PASSWORD=your_password_here

# ── S3 (증거 이미지/정적 자산) ───────────────────────────────
S3_BUCKET_NAME=the-verdict-assets-{본인학번}
